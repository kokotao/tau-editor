{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tau Editor",
  "version": "0.2.4",
  "identifier": "com.texteditor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Tau 编辑器",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "fileAssociations": [
      {
        "ext": ["txt", "text", "log", "conf", "cfg", "ini"],
        "name": "Text Document",
        "description": "Text Document",
        "mimeType": "text/plain",
        "role": "Editor"
      },
      {
        "ext": ["md", "markdown"],
        "name": "Markdown Document",
        "description": "Markdown Document",
        "mimeType": "text/markdown",
        "contentTypes": ["net.daringfireball.markdown", "public.plain-text"],
        "role": "Editor"
      },
      {
        "ext": ["json", "jsonc"],
        "name": "JSON Document",
        "description": "JSON Document",
        "mimeType": "application/json",
        "role": "Editor"
      },
      {
        "ext": ["yaml", "yml"],
        "name": "YAML Document",
        "description": "YAML Document",
        "mimeType": "application/x-yaml",
        "role": "Editor"
      },
      {
        "ext": ["toml"],
        "name": "TOML Document",
        "description": "TOML Document",
        "mimeType": "application/toml",
        "role": "Editor"
      },
      {
        "ext": ["js", "jsx", "ts", "tsx", "py", "java", "go", "rs", "c", "cpp", "h", "hpp", "cs", "sh", "bash", "zsh", "bat", "cmd", "ps1", "sql", "html", "htm", "css", "scss", "less", "xml"],
        "name": "Source Code",
        "description": "Source Code",
        "mimeType": "text/plain",
        "contentTypes": ["public.source-code"],
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}
